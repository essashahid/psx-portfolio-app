# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# cached filing PDFs (data/filings-cache/) — large binaries, rebuildable from
# data/filings-inventory.json, which records the source URL and fetch date
.cache/filings/

# typescript
*.tsbuildinfo
next-env.d.ts

# Local Claude Code settings (may contain machine-specific secrets)
.claude/settings.json

# Point-in-time data audits (generated by scripts/generate-coverage-report.ts) — regenerate, don't commit
reports/
