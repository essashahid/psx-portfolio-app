# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini (required for AI features)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-pro

# News providers
# Tavily is the primary web/news discovery provider when configured.
TAVILY_API_KEY=your-tavily-api-key
NEWS_ENABLE_TAVILY=true

# GDELT is a free secondary news source. It asks clients to stay near 1 request / 5 seconds.
NEWS_ENABLE_GDELT=true
GDELT_REQUEST_DELAY_MS=5500

# Official PSX company-announcement discovery. High-signal source for results,
# dividends, board meetings, material information, and other filings.
NEWS_ENABLE_PSX_ANNOUNCEMENTS=true

# Market data
# Options: psx, twelve-data, manual
MARKET_DATA_PROVIDER=psx
MARKET_DATA_API_KEY=
TWELVE_DATA_API_KEY=

# Foreign / local flows (FIPI / LIPI)
# Optional. NCCPL has no stable public API, so flows are entered manually in
# Settings → Foreign flows by default. If you have a JSON endpoint that returns
# the daily FIPI numbers (and optionally a `sectors` array), set it here and the
# market cron will auto-ingest it; otherwise leave unset and use manual entry.
NCCPL_FLOWS_URL=

APP_BASE_URL=http://localhost:3000
