# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini (required for AI features)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-pro

# News providers
# Market lane: free macro/policy/sector/international news from Pakistani
# business wires (Business Recorder, Dawn, Tribune) + Google News RSS. No key
# needed. This is what surfaces budget/policy/commodity/index news, not just
# company filings. Set to false to disable the market-wide feed.
NEWS_ENABLE_MARKET=true

# Tavily is an optional web/news discovery provider for per-holding deep search.
TAVILY_API_KEY=your-tavily-api-key
NEWS_ENABLE_TAVILY=true

# GDELT is a free secondary news source. It asks clients to stay near 1 request / 5 seconds.
NEWS_ENABLE_GDELT=true
GDELT_REQUEST_DELAY_MS=5500

# Official PSX company-announcement discovery. High-signal source for results,
# dividends, board meetings, material information, and other filings.
NEWS_ENABLE_PSX_ANNOUNCEMENTS=true

# Market data
# Options: psx, twelve-data, manual
MARKET_DATA_PROVIDER=psx
MARKET_DATA_API_KEY=
TWELVE_DATA_API_KEY=

# Foreign / local flows (FIPI / LIPI)
# Default: auto-fetch SCSTrade's public FIPI/LIPI tables, which attribute the
# source data to NCCPL. Set FOREIGN_FLOWS_PROVIDER=off to use manual entry only,
# or =custom with NCCPL_FLOWS_URL if you have your own JSON endpoint.
FOREIGN_FLOWS_PROVIDER=scstrade
NCCPL_FLOWS_URL=

APP_BASE_URL=http://localhost:3000
